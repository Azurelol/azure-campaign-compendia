<section class="nav">
    <nav class="tabs" aria-roledescription="{{localize "SHEETS.FormNavLabel"}}">
        {{#each tabs as |tab|}}
            {{#unless (eq tab.id "character")}}
                <a data-action="tab" data-group="{{tab.group}}" data-tab="{{tab.id}}"
                   class="button{{#if tab.cssClass}} {{tab.cssClass}}{{/if}}"
                   {{#if tab.tooltip}}data-tooltip="{{tab.tooltip}}"{{/if}}>
                    {{#if tab.icon}}<i class="{{tab.icon}}" inert></i>{{/if}}
                    {{#if tab.label}}<span>{{localize tab.label}}</span>{{/if}}
                </a>
            {{/unless}}
        {{/each}}
    </nav>
</section>
