<section class="tab planner {{tab.cssClass}}" data-tab="planner" data-group="primary">

    <div class="content">
        <div class="notes">
            <div class="title">
                <span>Notes</span>
            </div>

            <div class="toolbar acc-toolbar">
                <div class="acc-toolbar__row__flat">
                    <label class="acc-toolbar__search">
                        <input type="text" placeholder="..."/>
                    </label>
                    <button class="acc-button" data-action="addNote">
                        <i class="acc-icon --s {{accIconClass 'add'}}"></i>
                    </button>
                </div>
            </div>

            <div class="list">
                {{#each data.notes as |note|}}

                {{/each}}
            </div>
        </div>

        <div class="scenes">

        </div>
    </div>
</section>
