<a data-link draggable="true"
   data-uuid="{{uuid}}"
   data-item-id="{{id}}"
   data-pack="{{pack}}"
   class="{{classes}}"
   data-type="{{type}}" data-tooltip="{{name}}">
    {{#if img}}
        <img src="{{img}}" class="item-img acc-icon --{{size}}" alt="{{name}}">
    {{else}}
        <i class="item-img acc-icon --{{size}} {{accIconClass 'inspect'}}"></i>
    {{/if}}
</a>
