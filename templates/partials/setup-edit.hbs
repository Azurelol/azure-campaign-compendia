<div class="acc-property-section">
    <div class="acc-property-group">
        <label>
            Label
            <input type="text" name="{{path}}.label" maxlength="25" value="{{ data.label }}" data-dtype="String"/>
        </label>

        <label>
            Description
            <input type="text" name="{{path}}.description" maxlength="95" value="{{ data.description }}"
                   data-dtype="String"/>
        </label>
    </div>


    <h3>Choices</h3>
    <label title="Extended">
        Extended <input type="checkbox" name="{{path}}.extended" {{ checked data.extended }} />
    </label>
    <ol>
        {{#each data.choices as |choice index|}}
            <li>
                <label>
                    <input type="text" name="{{../path}}.choices.{{ index }}.text"
                           value="{{ choice.text }}"
                           maxlength="{{#if ../data.extended}}18{{else}}35{{/if}}"
                           data-dtype="String"/>
                </label>
            </li>
        {{/each}}
    </ol>
</div>

