<div class="form-group">

    <div class="inline-fields">
        <label>
            Label
            <input type="text" name="{{path}}.label" maxlength="18" value="{{ data.label }}" data-dtype="String"/>
        </label>

        <label>
            Clock
            <select name="{{path}}.clock" class="">
                {{selectOptions constants.clockSize selected=pool.clock sort=true localize=true blank="-"}}
            </select>
        </label>

        <label>
            Fail State
            <input type="text" name="{{path}}.failState" maxlength="32" value="{{ data.failState }}"
                   data-dtype="String"/>
        </label>
    </div>

    <h3>Traits</h3>
    <ol>
        {{#each data.traits as |entry index|}}
            <li>
                <label>
                    <input type="text" name="{{../path}}.traits.{{ index }}"
                           value="{{ entry }}"
                           data-dtype="String"/>
                </label>
            </li>
        {{/each}}
    </ol>

    <h3>Moves</h3>
    <ol>
        {{#each data.moves as |entry index|}}
            <li>
                <label>
                    <input type="text" name="{{../path}}.moves.{{ index }}"
                           value="{{ entry }}"
                           data-dtype="String"/>
                </label>
            </li>
        {{/each}}
    </ol>

    <h3>Description</h3>
    <div class="form-group">
        <prose-mirror name="{{path}}.description" value="{{data.description}}">
        </prose-mirror>
    </div>
</div>

