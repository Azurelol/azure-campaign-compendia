<article class="acc-story-kit__event">
    <header class="acc-story-kit__header">
        {{#if data.clock}}
            <span class="die">{{data.clock}}D</span>
        {{/if}}
        {{data.label}}
    </header>
    <section class="acc-story-kit__content">
        {{#if data.description}}
            {{{data.description}}}
        {{/if}}
        <ul class="acc-story-kit__event__list acc-story-kit__star">
            {{#each data.traits as |entry|}}
                {{#if entry}}
                    <li><i>{{entry}}</i></li>
                {{/if}}
            {{/each}}
        </ul>

        {{#if data.hasMoves}}
            <hr>
            <ul class="acc-story-kit__event__list acc-story-kit__dot bold" style="text-transform: uppercase;">
                {{#each data.moves as |entry|}}
                    {{#if entry}}
                        <li>{{entry}}</li>
                    {{/if}}
                {{/each}}
            </ul>
        {{/if}}

        {{#if data.hasFailState}}
            <hr>
            <div class="acc-story-kit__fail">✘ {{data.failState}}</div>
        {{/if}}
    </section>
</article>
