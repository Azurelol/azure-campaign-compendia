<div class="acc-property-section">
    <div class="acc-property-group --row">
        <label>
            Title
            <input type="text" name="{{path}}.label" maxlength="25" value="{{ pool.label }}" data-dtype="String"/>
        </label>

        <label>
            Clock
            <select name="{{path}}.clock" class="">
                {{selectOptions constants.clockSize selected=pool.clock sort=true localize=true blank="-"}}
            </select>
        </label>
    </div>

    <h3>Events</h3>
    <ol>
        <li>
            <label>
                <input type="text" name="{{path}}.event1" maxlength="40" value="{{ pool.event1 }}" data-dtype="String"/>
            </label>
        </li>
        <li>
            <label>
                <input type="text" name="{{path}}.event2" maxlength="40" value="{{ pool.event2 }}" data-dtype="String"/>
            </label>
        </li>
        <li>
            <label>
                <input type="text" name="{{path}}.event3" maxlength="40" value="{{ pool.event3 }}" data-dtype="String"/>
            </label>
        </li>
    </ol>
</div>

