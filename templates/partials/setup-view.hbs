<article class="acc-story-kit__box">
    <p><em><b>{{data.label}}</b>: {{data.description}}</em></p>
    <ul class="acc-story-kit__checklist {{#if data.extended}}--extended{{/if}}">
        {{#each data.choices as |choice index|}}
            {{#if choice.text}}
                <li>
                    {{choice.text}}
                </li>
            {{/if}}
        {{/each}}
    </ul>
</article>
